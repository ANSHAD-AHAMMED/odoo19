<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Reminder for due date and overdue -->
    <record forcecreate="True" id="ir_cron_due_email_scheduler" model="ir.cron">
        <field name="name">due date and overdue reminder email</field>
        <field name="model_id" ref="library_management.model_library_checkout"/>
        <field name="state">code</field>
        <field name="code">model.send_due_notifications()</field>
        <field eval="True" name="active"/>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="nextcall" eval="(DateTime.now() + timedelta(days=1))"/>
    </record>
</odoo>