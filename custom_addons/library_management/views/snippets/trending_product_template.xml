<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
   <template id="trending_product_template" name="Category Highlight">
       <section class="categories_section">
           <div class="container">
               <div class="alert alert-info">
                   <h4>Your Category Highlight Tab snippet will be displayed here...
                       Please save to view the snippet
                   </h4>
               </div>
           </div>
       </section>
   </template>
   <template id="trending_product_snippet" inherit_id="website.snippets"
             name="Trending Product Snippet">
       <xpath expr="//snippets[@id='snippet_groups']" position="inside">
           <t t-snippet="library_management.trending_product_template"
                  t-thumbnail="/library_management/static/src/image1.jpeg"/>
       </xpath>
       <xpath expr="//snippets[@id='snippet_structure']" position="inside">
           <t t-snippet="library_management.trending_product_template"/>
       </xpath>
   </template>
</odoo>
