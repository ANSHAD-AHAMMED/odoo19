<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="trending_product_template" name="Category Highlight">
        <section class="oe_structure container categories_section">
            <div class="row">
                <div class="col-md-12">
                    <div class="text-center py-5">
                        <h1 class="h1">Books</h1>
                        <div class="h3" style="text-align:center">Trending books</div>
                        <div id="courosel">
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>

    <template id="trending_product_snippet" inherit_id="website.snippets" priority="8">
        <xpath expr="//snippets[@id='snippet_groups']" position="inside">
            <t t-snippet="library_management.trending_product_template"
               t-thumbnail="/library_management/static/src/image1.jpeg"/>
        </xpath>

        <xpath expr="//snippets[@id='snippet_structure']" position="inside">
            <t t-snippet="library_management.trending_product_template"/>
        </xpath>
    </template>
</odoo>
