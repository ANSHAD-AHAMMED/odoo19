<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- Action -->
    <record id="action_author" model="ir.actions.act_window">
        <field name="name">Author</field>
        <field name="res_model">library.author</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No offers added yet</p>
        </field>
    </record>

    <!-- List View -->
    <record id="view_library_author_list" model="ir.ui.view">
        <field name="name">library.author.list</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_author_form" model="ir.ui.view">
        <field name="name">library.author.form</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                    </group>
                    <notebook>
                        <page string="Books">
                            <field name="book_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="price"/>
                                    <field name="status"/>
                                    <field name="publisher_id"/>
                                    <field name="genre_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>