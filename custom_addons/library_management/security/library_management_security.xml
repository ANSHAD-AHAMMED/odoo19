<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!--privilege-->
    <record model="res.groups.privilege" id="res_groups_privilege_library_management">
        <field name="name">Library Management</field>
    </record>

    <!--    library assistant group-->
    <record id="library_assistant_group" model="res.groups">
        <field name="name">library Assistant</field>
        <field name="privilege_id" ref="res_groups_privilege_library_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!--    librarian group -->
    <record id="library_librarian_group" model="res.groups">
        <field name="name">librarian</field>
        <field name="privilege_id" ref="res_groups_privilege_library_management"/>
        <field name="implied_ids" eval="[(4, ref('library_assistant_group'))]"/>
    </record>

    <!--    record rule for library assistant for checkout-->
    <record id="library_management_personal_checkouts" model="ir.rule">
        <field name="name">Library Management Personal Activities</field>
        <field ref="model_library_checkout" name="model_id"/>
        <field name="domain_force">['|',('create_uid','=',user.id),('create_uid','=',False)]</field>
        <field name="groups" eval="[(4, ref('library_management.library_assistant_group'))]"/>
    </record>

    <!--    record rule for librarian for checkout-->
    <record id="library_management_all_activities" model="ir.rule">
        <field name="name">All Activities</field>
        <field ref="model_library_checkout" name="model_id"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('library_management.library_librarian_group'))]"/>
    </record>

</odoo>
