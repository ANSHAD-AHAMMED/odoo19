<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
	<t t-name="library_management.category_data">
        <section class="categories_section">
			<div t-attf-id="{{ dynamic_id }}" class="container carousel slide" data-bs-ride="carousel"
                 t-att-data-bs-interval="interval">
				<div class="carousel-inner row w-100 mx-auto" role="listbox">
                    <t t-foreach="chunks" t-as="chunk" t-key="chunk_index">
						<div t-att-class="chunk.is_active ? 'carousel-item active' : 'carousel-item'">
							<div class="row p-5">
                                <t t-foreach="chunk" t-as="category" t-key="category.id">
                                    <div class="block span3 col-3">
										<div class="card-group">
											<div class="card">
                                                <img class="card-img-top"
                                                     t-attf-src="data:image/png;base64,{{category.cover_image}}"
                                                     style="padding: 0px; margin: 0px; height: 160px; width:305px;"/>
                                                <h5 class="mb-0"><t t-esc="category.name"/></h5>
												<p class="mb-0"><t t-esc="dynamic_id"/></p>
                                                <a t-attf-href="/slides/{{category.id}}"
														class="btn btn-primary" t-att-title="category.name">
														See Book details
												</a>
											</div>
										</div>
									</div>
								</t>
							</div>
						</div>
					</t>
				</div>
			</div>

            <a t-attf-href="##{ dynamic_id }" class="carousel-control-prev" data-bs-slide="prev" role="button"
               aria-label="Previous" title="Previous">
				<span class="fa fa-chevron-circle-left fa-2x" style="color: gray"/>
			</a>

            <a t-attf-href="##{ dynamic_id }" class="carousel-control-next" data-bs-slide="next" role="button"
               aria-label="Next" title="Next">##{ dynamic_id }
				<span class="fa fa-chevron-circle-right fa-2x" style="color: gray"/>
			</a>
		</section>
	</t>
</templates>
