<?xml version="1.0" encoding="UTF-8" ?>
<!--Product Category tab content template-->
<templates xml:space="preserve">
   <t t-name="library_management.category_data">
       <section class="categories_section">
           <div class="container">
               <h3 class="section_heading">Trending Books</h3>
               <div class="categories_wrapper">
                   <t t-foreach="result.categories" t-as="category" t-key="category.id">
                       <div class="categories">
                           <div class="img_wrapper">
                               <t t-if="category.cover_image">
                                   <img t-att-src="'data:image/png;base64,' + category.cover_image"
                                        class="img img-fluid rotate-center"
                                        t-att-alt="category.name or 'Category Image'"
                                        loading="lazy"/>
                               </t>
                               <t t-else="">
                                   <img src="/library_management/static/src/img/image1.jpg"
                                        class="img img-fluid rotate-center"
                                        alt="Default Category Image"
                                        loading="lazy"/>
                               </t>
                           </div>
                           <div class="type" style="font-weight: 700; font-size: 20px;">
                               <t t-esc="category.name"/>
                           </div>
                       </div>
                   </t>
               </div>
           </div>
       </section>
   </t>
</templates>
