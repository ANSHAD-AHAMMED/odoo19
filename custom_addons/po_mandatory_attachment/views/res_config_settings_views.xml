<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_po_mandatory" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.po_mandatory_attachment.require_attachment_on_purchase_order_confirmation
        </field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='purchase_setting_container']" position="inside">
                <setting string="Require Attachment On Purchase Order Confirmation"
                         help="Require Attachment On Purchase Order Confirmation"
                         id="require_attachment_on_purchase_order_confirmation">
                    <field name="require_attachment_on_purchase_order_confirmation"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
