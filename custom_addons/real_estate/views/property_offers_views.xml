<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action -->
    <record id="action_property_offers" model="ir.actions.act_window">
        <field name="name">Property offers</field>
        <field name="res_model">property.offer</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No offers added yet</p>
        </field>
    </record>

    <!-- List View -->
    <record id="view_property_offers_list" model="ir.ui.view">
        <field name="name">property.offer.list</field>
        <field name="model">property.offer</field>
        <field name="arch" type="xml">
            <list create="0">
                <field name="price"/>
                <field name="partner_id"/>
                <field name="properties_id"/>
                <field name="status"/>
                <field name="validity"/>
            </list>
        </field>
    </record>

</odoo>