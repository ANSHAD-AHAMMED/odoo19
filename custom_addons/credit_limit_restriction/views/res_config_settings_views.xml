<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.sale_discount_limit.discount_limit
        </field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="10"/>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pricing_setting_container']" position="inside">

                <setting string="Restricted Customer Tags"
                         help="restriction for customers if they have the same tags"
                         id="restricted_customer_tags_settings">
                    <field name="restricted_customer_tags" widget="many2many_tags"/>
                </setting>

                <setting string="Credit Limit Threshold"
                         help="restriction for customers if they reach the due amount"
                         id="credit_limit_threshold_settings">
                    <field name="credit_limit_threshold" widget="monetary"/>
                </setting>

            </xpath>
        </field>
    </record>
</odoo>