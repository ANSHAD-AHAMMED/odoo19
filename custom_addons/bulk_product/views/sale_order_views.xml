<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="bulk_product_inherited_sales_model_view_form" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.sale.order</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button id="add_to_order_line"
                        name="add_to_order_line"
                        string="Add Product"
                        type="object"
                        class="btn-primary"
                        invisible="state != 'draft'"
                />
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="products" invisible="state != 'draft'">
                                        <field name="bulk_product_ids" string="product">
                    <list editable="bottom">
                        <field name="product_id" string="product"/>
                        <field name="product_uom_qty" string="Quantity"/>
                    </list>
                                        </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
