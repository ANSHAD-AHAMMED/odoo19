<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- List View -->
    <record id="view_employee_loan_list" model="ir.ui.view">
        <field name="name">employee.loan.list</field>
        <field name="model">employee.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="loan_amount"/>
            </list>
        </field>
    </record>

    <!--       Form View -->
    <record id="view_employee_loan_form" model="ir.ui.view">
        <field name="name">employee.loan.form</field>
        <field name="model">employee.loan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <header>
                        <field name="state" widget="statusbar" status_visible="'draft', 'approved', 'ongoing', 'paid'"/>
                    </header>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="loan_amount"/>
                        <field name="installment_count"/>
                        <field name="start_date"/>
                        <field name="state"/>
                        <field name="loan_line_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_employee" model="ir.actions.act_window">
        <field name="name">Employee</field>
        <field name="res_model">employee.loan</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No offers added yet</p>
        </field>
    </record>

</odoo>